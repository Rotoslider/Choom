generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Choom {
  id            String    @id @default(cuid())
  companionId   String?   // Custom memory ID - if null, uses id. Allows memory isolation per Choom
  name          String
  description   String?
  avatarUrl     String?
  systemPrompt  String    @default("")
  imageSettings String?   // JSON string - Choom-specific image gen settings
  voiceId       String?   // TTS voice ID (per-Choom)
  llmModel      String?   // LLM model override (per-Choom)
  llmEndpoint   String?   // Optional LLM endpoint override
  llmProviderId String?   // External provider ID (references settings.providers[])
  llmTimeoutSec Int?      // LLM response timeout in seconds (default 120)
  llmFallbackModel1    String?  // First fallback model (on timeout/error)
  llmFallbackProvider1 String?  // First fallback provider ID
  llmFallbackModel2    String?  // Second fallback model (on timeout/error)
  llmFallbackProvider2 String?  // Second fallback provider ID
  avatarMode        String?   // 'off' | 'live' | 'desktop' (default null = off)
  avatar3dModelPath String?   // Relative path to GLB file (legacy)
  avatar3dStatus    String?   // 'generating' | 'ready' | 'failed' (legacy)
  avatar3dError     String?   // Error message if generation failed (legacy)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  chats         Chat[]
  images        GeneratedImage[]
}

model Chat {
  id                String    @id @default(cuid())
  title             String?
  choomId           String
  choom             Choom     @relation(fields: [choomId], references: [id], onDelete: Cascade)
  messages          Message[]
  archived          Boolean   @default(false)
  compactionSummary String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Message {
  id          String   @id @default(cuid())
  chatId      String
  chat        Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role        String   // 'user' | 'assistant' | 'system' | 'tool'
  content     String
  toolCalls   String?  // JSON string - Tool calls made by assistant
  toolResults String?  // JSON string - Results from tool execution
  createdAt   DateTime @default(now())
}

model GeneratedImage {
  id        String   @id @default(cuid())
  choomId   String
  choom     Choom    @relation(fields: [choomId], references: [id], onDelete: Cascade)
  prompt    String
  imageUrl  String
  settings  String?  // JSON string - Generation settings used
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  choomId   String?
  chatId    String?
  level     String   // info, success, warning, error
  category  String   // llm, tts, stt, image, memory, agent, system
  title     String
  message   String
  details   String?  // JSON
  duration  Int?
  createdAt DateTime @default(now())
}

model Notification {
  id           String   @id @default(cuid())
  choomId      String
  message      String
  imageIds     String?  // JSON array of GeneratedImage IDs to attach
  filePaths    String?  // JSON array of absolute workspace file paths to attach
  includeAudio Boolean  @default(true)
  delivered    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Settings {
  id         String   @id @default("global")
  llm        String   // JSON string - LLM endpoint, model, params
  tts        String   // JSON string - TTS endpoint, voice
  stt        String   // JSON string - STT endpoint
  imageGen   String   // JSON string - Forge endpoint, defaults
  weather    String   // JSON string - Weather API config
  search     String   // JSON string - Search API config
  memory     String   // JSON string - Memory server config
  appearance String   // JSON string - Theme, dark mode
  updatedAt  DateTime @updatedAt
}

// ============================================================================
// Habit Tracker
// ============================================================================

model HabitEntry {
  id        String   @id @default(cuid())
  choomId   String   // Which Choom recorded this entry
  category  String   // e.g. "vehicle", "hygiene", "shopping", "outdoor", "maintenance", "health"
  activity  String   // e.g. "filled gas", "shower", "went to Walmart"
  location  String?  // Optional: "Lake Tahoe", "Shell on 5th"
  notes     String?  // Optional freeform notes
  quantity  Float?   // Optional: 15.5 gallons, $47.50
  unit      String?  // Optional: "gallons", "$", "miles"
  timestamp DateTime @default(now()) // When the activity happened
  createdAt DateTime @default(now())

  @@index([choomId])
  @@index([category])
  @@index([timestamp])
  @@index([activity])
}

model HabitCategory {
  id          String  @id @default(cuid())
  name        String  @unique // "vehicle", "hygiene", etc.
  icon        String? // Emoji for display (e.g. "🚗")
  color       String? // Hex color for charts (e.g. "#3b82f6")
  description String?
}

// ============================================================================
// Token Usage Tracking
// ============================================================================

model TokenUsage {
  id               String   @id @default(cuid())
  choomId          String   // Which Choom made the request
  choomName        String   // Choom display name (denormalized for easy querying)
  chatId           String?  // Chat session (null for delegation/heartbeat)
  model            String   // LLM model name used
  provider         String   // Provider: "local", "anthropic", "openai", etc.
  endpoint         String?  // API endpoint URL
  promptTokens     Int      @default(0) // Input tokens
  completionTokens Int      @default(0) // Output tokens
  totalTokens      Int      @default(0) // Total tokens (prompt + completion)
  iterations       Int      @default(1) // Agentic loop iterations
  toolCalls        Int      @default(0) // Number of tool calls in request
  toolNames        String?  // JSON array of tool names used
  durationMs       Int?     // Wall-clock duration in milliseconds
  source           String   @default("chat") // "chat", "delegation", "heartbeat", "compaction"
  timestamp        DateTime @default(now())

  @@index([choomId])
  @@index([model])
  @@index([provider])
  @@index([timestamp])
  @@index([source])
}
